<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_bg">

    <!-- Main vertical layout -->
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <!-- Top bar with back button and title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/backBtn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="14dp"
                android:elevation="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:padding="10dp"
                app:backgroundTint="@android:color/transparent"
                app:cornerRadius="20dp"
                app:icon="@drawable/baseline_arrow_back_24"
                app:iconGravity="textStart"
                app:strokeColor="#FFCC93"
                app:strokeWidth="2dp"
                app:iconPadding="0dp"
                app:iconSize="25dp"
                app:iconTint="#FFCC93"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sizzling Menu"
                android:textSize="40sp"
                android:fontFamily="@font/margarine"
                android:textColor="@color/white"/>
        </LinearLayout>

        <!-- RecyclerView for Silog items -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/sizzlingRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="20dp"
            android:clipToPadding="false"
            android:paddingBottom="80dp"/> <!-- leave space for floating panel -->

    </LinearLayout>

    <!-- Floating Cart Panel -->
    <LinearLayout
        android:id="@+id/floatingCartPanel"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#FFCC93"
        android:gravity="center_vertical"
        android:elevation="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/cartItemCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cart: 0 items"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/goToCartBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="View Cart"
            android:backgroundTint="#ffffff"
            android:textColor="#FFCC93"
            app:cornerRadius="12dp"/>
    </LinearLayout>

</FrameLayout>