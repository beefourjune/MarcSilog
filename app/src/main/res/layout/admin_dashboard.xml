<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_bg_admin">

    <!-- Title -->
    <TextView
        android:id="@+id/adminTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/manrope_extrabold"
        android:text="Admin Dashboard"
        android:textColor="@color/black"
        android:textSize="26sp"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/adminTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/backtostartbtn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="10dp"
            android:elevation="8dp"
            app:backgroundTint="@android:color/white"
            app:cornerRadius="20dp"
            app:icon="@drawable/baseline_arrow_back_24"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="25dp"
            app:iconTint="#B73B28"/>

        <EditText
            android:id="@+id/searchBar"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/rounded_edittext"
            android:hint="Search food..."
            android:padding="10dp"
            android:textSize="15sp"/>
    </LinearLayout>

    <!-- Pending Orders / Kitchen Queue -->
    <LinearLayout
        android:id="@+id/pendingSection"
        android:layout_width="0dp"
        android:layout_height="90dp"
        android:orientation="vertical"
        android:elevation="8dp"
        android:padding="12dp"
        android:backgroundTint="#F77A33"
        android:background="@drawable/rounded_button"
        android:layout_margin="12dp"
        android:clipToPadding="false"
        android:clipChildren="false"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/pendingOrdersText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pending Orders:"
            android:textColor="#000"
            android:fontFamily="@font/manrope_medium"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/kitchenQueueText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kitchen Queue:"
            android:textColor="#000"
            android:textSize="14sp"
            android:fontFamily="@font/manrope_medium"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- Tabs -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        app:tabIndicatorColor="#FFC107"
        app:tabSelectedTextColor="#000"
        app:tabTextColor="#777"
        app:layout_constraintTop_toBottomOf="@id/pendingSection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/white"
        app:layout_constraintTop_toBottomOf="@id/tabLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- Orders Feed -->
    <ListView
        android:id="@+id/listViewOrders"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:divider="@android:color/darker_gray"
        android:dividerHeight="1dp"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/tabLayout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>