<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Title -->

    <!-- Top Bar -->
    <TextView
        android:id="@+id/adminTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="25dp"
        android:layout_marginStart="8dp"
        android:fontFamily="@font/inter_extrabold"
        android:text="Admin Dashboard"
        android:textColor="#000"
        android:textSize="26sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.064"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="5dp"
        android:layout_marginStart="5dp"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/adminTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/backtostartbtn"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginEnd="8dp"
            android:elevation="8dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:padding="10dp"
            app:backgroundTint="@android:color/transparent"
            app:cornerRadius="20dp"
            app:icon="@drawable/baseline_arrow_back_24"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="23dp"
            app:iconTint="#B73B28"/>

        <EditText
            android:id="@+id/searchBar"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/rounded_edittext"
            android:hint="Search food..."
            android:padding="10dp"
            android:textSize="15sp"/>
    </LinearLayout>

    <!-- Pending Orders / Kitchen Queue -->
    <LinearLayout
        android:id="@+id/dashboardSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_margin="12dp"
        android:gravity="center"
        android:weightSum="2"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Pending Orders Card -->
        <LinearLayout
            android:id="@+id/pendingCard"
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:backgroundTint="#F77A33"
            android:gravity="center"
            android:background="@drawable/rounded_button"
            android:elevation="6dp"
            android:padding="16dp"
            android:layout_marginEnd="6dp">

            <TextView
                android:id="@+id/pendingNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12"
                android:textSize="32sp"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:fontFamily="@font/manrope_bold"/>

            <TextView
                android:id="@+id/pendingOrdersText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pending Orders"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:fontFamily="@font/manrope_medium"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Kitchen Queue Card -->
        <LinearLayout
            android:id="@+id/kitchenCard"
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/rounded_button"
            android:backgroundTint="#FFCD93"
            android:elevation="6dp"
            android:padding="16dp"
            android:layout_marginStart="6dp">

            <TextView
                android:id="@+id/kitchenNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5"
                android:textSize="32sp"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:fontFamily="@font/manrope_bold"/>

            <TextView
                android:id="@+id/kitchenQueueText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kitchen Queue"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:fontFamily="@font/manrope_medium"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Tabs -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        app:tabIndicatorColor="#FFC107"
        app:tabSelectedTextColor="#000"
        app:tabTextColor="#777"
        app:layout_constraintTop_toBottomOf="@id/dashboardSection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/white"
        app:layout_constraintTop_toBottomOf="@id/tabLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- Orders Feed -->
    <ListView
        android:id="@+id/listViewOrders"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:divider="@android:color/darker_gray"
        android:dividerHeight="1dp"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/tabLayout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>