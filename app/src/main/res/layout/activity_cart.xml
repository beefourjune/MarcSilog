<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/gradient_bg">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        >


        <!-- Back button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/backBtn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="14dp"
            android:elevation="8dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:padding="10dp"
            app:backgroundTint="@android:color/transparent"
            app:cornerRadius="20dp"
            app:icon="@drawable/baseline_arrow_back_24"
            app:iconGravity="textStart"
            app:strokeColor="#FFCC93"
            app:strokeWidth="2dp"
            app:iconPadding="0dp"
            app:iconSize="25dp"
            app:iconTint="#FFCC93"
            />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Cart"
            android:textSize="40sp"
            android:fontFamily="@font/margarine"
            android:textColor="@color/white"
            />

    </LinearLayout>


    <!-- Empty cart message -->
    <TextView
        android:id="@+id/cartEmptyText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cart is empty"
        android:textSize="18sp"
        android:layout_gravity="center"
        android:paddingTop="50dp"
        android:visibility="gone"/>

    <!-- Scrollable container for cart items -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="#F5F5F5">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Scrollable cart items -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <LinearLayout
                    android:id="@+id/cartContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </ScrollView>

            <!-- Total inside the card -->
            <TextView
                android:id="@+id/cartTotalText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Total: ₱0.00"
                android:textSize="20sp"
                android:textColor="@color/black"
                android:fontFamily="@font/manrope_bold"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:visibility="gone"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Place Order button outside -->
    <Button
        android:id="@+id/orderBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Place Order"
        android:textSize="15sp"
        android:fontFamily="@font/manrope_extrabold"
        android:backgroundTint="#FFD54F"
        android:textColor="@android:color/black"
        android:padding="10dp"
        android:visibility="gone"/>
</LinearLayout>