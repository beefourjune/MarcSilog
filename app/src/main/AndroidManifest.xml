<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"

    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET"/>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Kiosk"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".LoginActivity"
            android:exported="false"/>

        <activity
            android:name="com.example.kiosk.MainMenu"
            android:exported="false" />

        <activity
            android:name=".CartActivity"
            android:exported="false" />

        <activity android:name=".PaymentActivity" />
        <activity android:name=".AdminDashboard" />
        <activity android:name=".SilogActivity" />
        <activity android:name=".PastilActivity" />
        <activity android:name=".ShawarmaActivity" />
        <activity android:name=".SizzlingActivity" />
        <activity android:name=".SSDActivity" />
        <activity android:name=".DrinksActivity" />
        <activity android:name=".OrderReceivedActivity" />
        <activity android:name=".AddOnsActivity" />



        <activity
            android:name=".StartOrder"
            android:exported="true"
            android:label="@string/title_activity_start_order"
            android:theme="@style/Theme.Kiosk" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <meta-data
            android:name="preloaded_fonts"
            android:resource="@array/preloaded_fonts" />

    </application>

</manifest>